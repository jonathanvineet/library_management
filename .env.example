# ===================================
# SUPABASE REST API CONFIGURATION (ONLY!)
# ===================================
# No database credentials needed - uses Supabase REST API endpoints only

# Supabase Project URL
# Get from: Supabase Dashboard > Project Settings > API > Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key
# Get from: Supabase Dashboard > Project Settings > API > Anon/Public Key
# This is the ONLY credential needed for REST API operations
SUPABASE_ANON_KEY=your-anon-key-here

# ===================================
# APPLICATION CONFIGURATION
# ===================================

# Server Port
SERVER_PORT=8080

# Spring Profile (Supabase REST API)
# Always use 'prod' for REST API integration
SPRING_PROFILES_ACTIVE=prod

