# ===================================
# SUPABASE CONFIGURATION
# ===================================

# Supabase Project URL
# Find this in: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anon/Public Key
# Find this in: Supabase Dashboard > Project Settings > API
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase PostgreSQL Direct Connection
# Find this in: Supabase Dashboard > Project Settings > Database > Connection Pooling
SUPABASE_DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USERNAME=postgres.your-project-ref
SUPABASE_DB_PASSWORD=your-database-password-here

# ===================================
# APPLICATION CONFIGURATION
# ===================================

# Server Port
SERVER_PORT=8080

# Spring Profile (dev = H2 database, prod = Supabase)
SPRING_PROFILES_ACTIVE=dev

# ===================================
# CONNECTION POOL SETTINGS
# ===================================

HIKARI_MAX_POOL_SIZE=10
HIKARI_MIN_IDLE=5

# ===================================
# LEGACY: Azure SQL Database Configuration
# (Commented out - now using Supabase)
# ===================================

# AZURE_SQL_SERVER=your-server-name.database.windows.net
# AZURE_SQL_DATABASE=library_management_db
# AZURE_SQL_USERNAME=your-username
# AZURE_SQL_PASSWORD=your-password

