# Root .gitignore for Library Management System

# OS Files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.iml

# Logs
*.log
logs/

# Environment files (keep .env.example)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Database files (local H2 databases)
data/
*.mv.db
*.trace.db

# Temporary files
*.tmp
*.temp
temp/
tmp/

# Documentation files (except root README.md)
*.md
!README.md

# SQL scripts (optional - uncomment if you don't want to track them)
# *.sql
